---
import '../styles/global.css';

const { title, description, lang = 'zh-CN' } = Astro.props;
const base = (import.meta.env.BASE_URL || '/').replace(/\/?$/, '/');
const withBase = (segment = '') => `${base}${segment.replace(/^\//, '')}`;
---

<!doctype html>
<html lang={lang} class="h-full">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" sizes="16x16" href={withBase('favicon-16.png')} />
    <link rel="icon" type="image/png" sizes="32x32" href={withBase('favicon-32.png')} />
  </head>
  <body class="min-h-full font-sans antialiased">
    <slot />
  </body>
</html>
